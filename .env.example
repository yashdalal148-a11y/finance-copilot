# ──────────────────────────────────────────────
# Finance Intelligence Copilot — Environment
# ──────────────────────────────────────────────

# Required: Google Gemini API key
GEMINI_API_KEY=

# Optional: Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Required: Groq API key
GROQ_API_KEY=gsk_

# Required: OpenRouter API key
OPENROUTER_API_KEY=

# Optional: Whisper model size (tiny, base, small, medium, large-v3)
WHISPER_MODEL_SIZE=base

# Optional: Whisper device (cpu or cuda)
WHISPER_DEVICE=cpu

# Optional: Whisper compute type (int8, float16, float32)
WHISPER_COMPUTE_TYPE=int8

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
